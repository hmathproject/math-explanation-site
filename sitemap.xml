---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
  {% unless page.url contains '/assets/' or page.url == '/robots.txt' or page.url == '/sitemap.xml' %}
  {% if page.url %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
  </url>
  {% endif %}
  {% endunless %}
  {% endfor %}
</urlset>
